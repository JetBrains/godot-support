<idea-plugin url="https://github.com/JetBrains/godot-support">
  <id>com.intellij.rider.godot.community</id>
  <name>Godot Support (Technical)</name>
  <version>2.0.0</version>
  <vendor url="https://www.jetbrains.com">JetBrains</vendor>

  <description><![CDATA[
<strong>This plugin is a mediator between Rider Godot support plugin and GdScript IntelliJ plugin.</strong>
<p>Referenced from the Godot support plugin</p>
<p>Referenced from the GdScript plugin</p>
<p>Provides a set of extension points between those plugins.</p>
]]>
  </description>

  <depends>com.intellij.modules.platform</depends>
  <extensions defaultExtensionNs="com.intellij">
  </extensions>

  <extensionPoints>
    <extensionPoint name="godotProjectProvider" interface="com.jetbrains.rider.godot.community.GodotProjectProvider" dynamic="true" />
    <extensionPoint name="editorConnectionProvider" interface="com.jetbrains.rider.godot.community.GodotEditorConnectionProvider" dynamic="true"/>
  </extensionPoints>

  <extensions defaultExtensionNs="com.intellij">
    <fileType name="GdScript" implementationClass="com.jetbrains.rider.godot.community.gdscript.GdFileType" fieldName="INSTANCE" language="GdScript" extensions="gd;gdf"/>
    <fileType name="Tscn file" implementationClass="com.jetbrains.rider.godot.community.tscn.TscnFileType" fieldName="INSTANCE" language="Tscn" extensions="tscn"/>
    <postStartupActivity implementation="com.jetbrains.rider.godot.community.GodotMetadataFileWatcherManager"/>
  </extensions>

  <actions>
    <group id="GodotActionsToolbar" popup="true" class="com.jetbrains.rider.godot.community.actions.GodotActionsToolbar" icon="com.intellij.rider.plugins.godot.community.icons.RiderPluginsGodotCommunityIcons.Godot">
      <add-to-group group-id="MainToolbarRight" anchor="first" />
      <action id="StartGodotEditorAction"
              class="com.jetbrains.rider.godot.community.actions.StartGodotEditorAction"
              icon="AllIcons.Actions.Execute">
      </action>
    </group>
  </actions>

  <resource-bundle>messages.GodotCommunityBundle</resource-bundle>

</idea-plugin>
